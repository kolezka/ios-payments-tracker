# SMTP (for magic link emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Payment Tracker <noreply@example.com>

# GitHub OAuth (hidden by default, set ENABLE_GITHUB_LOGIN=true to show)
ENABLE_GITHUB_LOGIN=false
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Database
# docker-compose db service credentials (only used on first volume init):
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=payment_tracker
# API connection string (set this in Coolify to match your DB credentials):
DATABASE_URL=postgres://postgres:postgres@db:5432/payment_tracker

# App
DEV_MODE=true  # skip login/auth for local development
BASE_URL=http://localhost:5173
API_URL=http://localhost:3010
LOG_LEVEL=debug

# Apple Shortcut (optional)
# Share a shortcut via iCloud and paste the link here for one-tap install
# ICLOUD_SHORTCUT_URL=https://www.icloud.com/shortcuts/...

# Feature flags (all shown by default, set to "false" to hide)
# SHOW_DOWNLOAD_SHORTCUT=true
# SHOW_ADD_SHORTCUT=true
# SHOW_SHORTCUT_WIDGET=true
