# ============================================================
# Payment Tracker - Environment Configuration
# ============================================================
# Copy to .env and fill in required values before deployment.
# Values marked REQUIRED have no safe default.

# ---- Database ----
# Superuser credentials (only used on first volume initialization)
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_SUPERUSER_PASSWORD

# Application database user (restricted privileges, used by the API)
APP_DB_USER=app
APP_DB_PASSWORD=CHANGE_ME_APP_PASSWORD          # REQUIRED

DB_NAME=payment_tracker

# Override the full connection string (optional, built automatically if unset)
# DATABASE_URL=postgres://app:password@db:5432/payment_tracker

# ---- SMTP (for magic link emails) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=Payment Tracker <noreply@example.com>

# ---- GitHub OAuth (optional) ----
ENABLE_GITHUB_LOGIN=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- App ----
# IMPORTANT: Never set DEV_MODE=true in production
DEV_MODE=false
LOG_LEVEL=info

# Public URL of the web frontend (used for CORS, email links, OAuth redirects)
# SERVICE_URL_WEB=https://your-domain.com

# ---- Apple Shortcut (optional) ----
# ICLOUD_SHORTCUT_URL=https://www.icloud.com/shortcuts/...

# ---- Feature flags ----
# SHOW_DOWNLOAD_SHORTCUT=true
# SHOW_ADD_SHORTCUT=true
# SHOW_SHORTCUT_WIDGET=true
